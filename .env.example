# Copy this file to .env and fill in your values

# ── REQUIRED ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AUDIERA_API_KEY=sk_audiera_...
AUDIERA_ARTIST_ID=your_artist_id_from_audiera_profile

# ── Wallet ───────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_64_char_hex_private_key
WALLET_ADDRESS=0x_your_wallet_address

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── BSC Contracts (pre-filled) ───────────────────────────────────────────────
VOTING_CONTRACT_ADDRESS=0xe554229ba6ec7ceeacd13a9bb48d812bf705c292
STAKING_CONTRACT_ADDRESS=0x0d956565253b74b84c4daa51e026bbb4c215020e
BSC_RPC_URL=https://bsc-rpc.publicnode.com

# ── X / Twitter (optional) ───────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── Behaviour ─────────────────────────────────────────────────────────────────
MOCK_MODE=false
API_HOST=0.0.0.0
API_PORT=8000
